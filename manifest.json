{
  "manifest_version": 2,
  "name": "Tab Switcher",
  "version": "1.0.0",
  "description": "Shows all open tabs in the right-click context menu for quick switching.",
  "permissions": [
    "tabs",
    "contextMenus"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-switcher@addon",
      "strict_min_version": "57.0"
    }
  }
}
